# 템플릿: 아래 항목을 .env.development 또는 .env.production 에 맞게 복사해 사용.
# 앱은 ENV 값에 따라 .env.{ENV} 만 로드함 (예: ENV=development → .env.development). 단일 .env 파일은 사용하지 않음.

ENV=development
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=puppytalk

# 서버
HOST=0.0.0.0
PORT=8000
# [배포 시 수정] 배포 시 false 로 설정
DEBUG=True

# [배포 시 수정] 프론트 주소 (127.0.0.1로만 접속 시 하나만)
CORS_ORIGINS=http://127.0.0.1:5500

# 세션
SESSION_EXPIRY_TIME=86400
# 만료 세션 정리 주기(초). 0이면 시작 시 1회만 실행
SESSION_CLEANUP_INTERVAL=3600
# [배포 시 수정] HTTPS 배포 시 true (Set-Cookie secure 플래그)
COOKIE_SECURE=false

# Rate limit 분산. 비우면 인메모리(워커별). 설정 시 Redis 사용(멀티 워커/인스턴스 공통)
# REDIS_URL=redis://localhost:6379/0

# 로깅
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR
# LOG_FILE_PATH: 비우면 로그는 콘솔만. 경로 넣으면 해당 파일에도 기록 (예: logs/app.log, 5MB 단위 로테이팅)
LOG_LEVEL=INFO
LOG_FILE_PATH=

# Rate limiting
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100
# 로그인 전용 (브루트포스 방지)
LOGIN_RATE_LIMIT_WINDOW=60
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
# ALB/Nginx 등 프록시 뒤에 둘 때 true. 직접 노출 시 false (로컬·직접 노출 시 위조 방지)
TRUST_X_FORWARDED_FOR=false

# 회원가입용 프로필 이미지 (비로그인 업로드)
SIGNUP_IMAGE_TOKEN_TTL_SECONDS=3600
SIGNUP_UPLOAD_RATE_LIMIT_WINDOW=3600
SIGNUP_UPLOAD_RATE_LIMIT_MAX=10

# 파일 업로드
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png

# [배포 시 수정] API 기본 URL (이미지 등 링크 생성에 사용)
BE_API_URL=http://127.0.0.1:8000

# [배포 시 수정] 파일 저장소 (배포 시 s3 권장)
STORAGE_BACKEND=local
S3_BUCKET_NAME=s3 사용 시 버킷 이름
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=s3 사용 시 IAM 액세스 키
AWS_SECRET_ACCESS_KEY=s3 사용 시 IAM 시크릿 키
# S3 공개 URL 접두사 (선택, CloudFront 쓰면 여기 설정)
S3_PUBLIC_BASE_URL=CloudFront 등 공개 URL 접두사
