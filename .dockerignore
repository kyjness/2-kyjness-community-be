# Git
.git
.gitignore

# 환경/비밀 (이미지에 넣지 않음, 런타임에 주입)
.env
.env.*
!.env.example

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
.venv
venv
env

# 문서 (이미지 크기 절감)
docs
*.md
!README.md

# 개발 전용 (테스트 스위트는 재구성 전까지 제외)
typings/
.pytest_cache/

# IDE
.idea
.vscode
*.swp
*.swo

# 기타
*.log
upload/*
!upload/.gitkeep
